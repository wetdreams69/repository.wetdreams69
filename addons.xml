<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.video.mercadoplay"
       name="MercadoLibre Play"
       version="1.0.1"
       provider-name="wetdreams69">
    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
        <import addon="script.module.requests" version="2.18.4"/>
        <import addon="inputstream.adaptive" version="2.0.12"/>
        <import addon="script.module.beautifulsoup4" version="4.5.3"/>
        <import addon="script.module.inputstreamhelper"/>
    </requires>
    <extension point="xbmc.python.pluginsource"
               library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Streaming de películas y series desde MercadoLibre</summary>
        <description lang="es">Addon no oficial para ver contenido desde play.mercadolibre.com.ar con soporte para DRM Widevine</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <language>resources/language</language>
        <license>MIT</license>
        <source>https://github.com/wetdreams69/plugin.video.mercadoplay</source>
    </extension>
</addon>

<addon id="plugin.video.pluto_vod" name="Pluto VOD" version="0.0.3">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="inputstream.adaptive" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
</addon>

<addon id="plugin.video.youtubemovieslatino"
       name="YouTube Movies Latino"
       version="1.0.0"
       provider-name="wetdreams69">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.18.4"/>
        <import addon="plugin.video.youtube" version="7.0.1"/>
    </requires>

    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="es">Muestra películas de YouTube</summary>
        <description lang="es">Este addon lista películas de YouTube.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <license>MIT</license>
        <language>es</language>
        <website>https://github.com/wetdreams69/plugin.video.youtubemovieslatino</website>
    </extension>

</addon>


<addon id="repository.wetdreams69" name="wetdreams69 Repository" version="1.0.0" provider-name="wetdreams69">
    <extension point="xbmc.addon.repository" name="wetdreams69 Repository">
        <dir>
            <info compressed="false">https://wetdreams69.github.io/repository.wetdreams69/addons.xml</info>
            <checksum>https://wetdreams69.github.io/repository.wetdreams69/addons.xml.md5</checksum>
            <datadir zip="true">https://wetdreams69.github.io/repository.wetdreams69/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>wetdreams69 Repository</summary>
        <description>Repositorio de addons de wetdreams69 (MercadoPlay, Pluto VOD, Youtube Latino)</description>
        <platform>all</platform>
    </extension>
</addon>

</addons>
